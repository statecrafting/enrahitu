# enrahitu non-secret runtime configuration (loaded by `encore run`).
# Secrets (JWT keys, RAUTHY_CLIENT_SECRET) go through `encore secret set`,
# with a dev fallback to keys/*.pem from `npm run generate-keys`.

AUTH_DRIVER=mock
FRONTEND_URL=http://localhost:5173
LOG_PII=false

# CoreLedger (libSQL). Defaults to a local file; set the sync knobs to turn
# it into a Turso embedded replica.
#ENRAHITU_LEDGER_URL=file:./.data/ledger/enrahitu.db
#ENRAHITU_LEDGER_SYNC_URL=libsql://<db>.turso.io
#ENRAHITU_LEDGER_AUTH_TOKEN=
#ENRAHITU_LEDGER_SYNC_INTERVAL_SECS=60

# Embedded hiqlite (cache/KV + rate-limit counters). Defaults are fine in dev.
#ENRAHITU_HIQ_DATA_DIR=./.data/hiqlite
#ENRAHITU_HIQ_ADDR_RAFT=127.0.0.1:8100
#ENRAHITU_HIQ_ADDR_API=127.0.0.1:8200
#ENRAHITU_HIQ_SECRET_RAFT=
#ENRAHITU_HIQ_SECRET_API=

# rauthy (OIDC), Phase 3. In the enrahitu container the issuer is same-origin
# through the idp proxy. The trailing slash is required: rauthy advertises its
# issuer as .../auth/v1/ and openid-client validates it exactly (matches
# docker/entrypoint.sh and spec 005).
#RAUTHY_ISSUER=http://localhost:4000/auth/v1/
#RAUTHY_CLIENT_ID=enrahitu
#RAUTHY_REDIRECT_URI=http://localhost:4000/api/v1/auth/rauthy/callback
#RAUTHY_SCOPES=openid profile email groups
#RAUTHY_DEFAULT_ROLE=user
