{
  "name": "@enrahitu/hiqlite-native",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "spec-spine": { "spec": "002-in-process-hiqlite" },
  "description": "In-process hiqlite (cache/KV + counters) as a napi-rs native addon for EnRaHiTu. Prebuilt per-platform binaries ship as optional dependencies (spec 018).",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=24" },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "hiqlite-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts",
    "prepublish:napi": "napi prepublish -t npm --skip-gh-release"
  },
  "optionalDependencies": {
    "@enrahitu/hiqlite-native-darwin-arm64": "0.1.0",
    "@enrahitu/hiqlite-native-linux-x64-gnu": "0.1.0",
    "@enrahitu/hiqlite-native-linux-arm64-gnu": "0.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.1.5"
  }
}
