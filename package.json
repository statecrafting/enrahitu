{
  "name": "enrahitu",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "spec-spine": {
    "spec": "001-enrahitu-architecture"
  },
  "type": "module",
  "description": "EnRaHiTu: Encore.ts + rauthy + hiqlite + Turso/libSQL on the @statecrafting build toolchain (Encore rust core + js runtime via napi-rs, no encore CLI): a self-contained, single-container application core with zero managed-infrastructure dependencies.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "enrahitu-dev",
    "build:app": "enrahitu-build",
    "extract:model": "enrahitu-build && enrahitu-extract",
    "check:model": "enrahitu-extract --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "generate-keys": "tsx scripts/generate-keys.ts",
    "dev:idp": "docker compose -f docker/compose.dev.yml up -d && node scripts/sync-dev-rauthy-secret.mjs",
    "dev:idp-secret": "node scripts/sync-dev-rauthy-secret.mjs",
    "dev:web": "npm --prefix frontend run dev",
    "build:web": "npm --prefix frontend run build",
    "test:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-trace-base": "^2.10.0",
    "@opentelemetry/sdk-trace-node": "^2.10.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@statecrafting/hiqlite-native": "^0.1.0",
    "@statecrafting/kernel-native": "^0.1.0",
    "encore.dev": "^1.57.9",
    "jsonwebtoken": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@statecrafting/toolchain": "^0.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
