# Enforce LF line endings for all text files in this repository.
# This prevents "LF will be replaced by CRLF" warnings on Windows
# and ensures consistent line endings across all platforms.

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# --- Source code ---
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.vue       text eol=lf

# --- Config / markup ---
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf

# --- Docs ---
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf

# --- Shell / config ---
*.sh        text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
.env*       text eol=lf
Dockerfile* text eol=lf
*.dockerfile text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.eslintrc*  text eol=lf
.prettierrc* text eol=lf

# --- Binary — never touch line endings ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary

# Binary test fixtures in the vendored Encore workspace must never be
# line-ending normalized.
*.bin binary

# --- Stamped-tree slimming (spec 018) ---
# The vendored Encore toolchain leaves the STAMPED tree but stays in this
# repo to build the @enrahitu/toolchain packages. `git archive` (what the
# Statecraft factory uses to export a stamp, spec 005) honours export-ignore,
# so these heavy build-source subtrees are excluded from every stamp. This
# mirrors the docker build-context exclusions in .dockerignore. The encore.dev
# JS runtime (vendor/encore/runtimes/js/encore.dev) is deliberately NOT
# ignored: a stamped app resolves it through the node_modules symlink.
vendor/encore/target                 export-ignore
vendor/encore/target-linux           export-ignore
vendor/encore/tsparser               export-ignore
vendor/encore/miniredis              export-ignore
vendor/encore/proto                  export-ignore
vendor/encore/runtimes/core          export-ignore
vendor/encore/runtimes/js/src        export-ignore
vendor/encore/runtimes/js/build.rs   export-ignore
vendor/encore/runtimes/js/Cargo.toml export-ignore
vendor/encore/Cargo.toml             export-ignore
vendor/encore/Cargo.lock             export-ignore
